# Local / large geodata (keep raw GeoJSON and archives out of Git by default)
data/raw/*.geojson
data/raw/*.zip
data/raw/*.gpkg
data/raw/*.shp
data/raw/*.dbf
data/raw/*.shx
data/raw/*.prj
data/raw/*.cpg

# Generated outputs (uncomment if you prefer not to track ensemble outputs)
# results/

# Large processed spatial layers (keep manifests / small artifacts if desired)
data/processed/*.parquet
data/processed/*.geojson
data/processed/graph/*.parquet
data/processed/graph/*.json
data/processed/graph/*.html

# Per-run pipeline outputs (county mode, rollups); regenerate with pipeline
data/processed/runs/

# Local scratch (redist / ad-hoc runs)
_redist_debug/
_t4326/
